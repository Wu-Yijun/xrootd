{
  name: '@aluria/xrootd-node',
  version: '1.0.0',
  description: 'Prebuilt Node.js Native Addon for XRootD',
  main: 'dist/index.js',
  types: 'dist/index.d.ts',
  scripts: {
    'build:ts': 'tsc',
    'build:addon': 'node-gyp rebuild',
    // --strip 会移除 C++ 调试符号，大幅减小最终包的体积
    prebuild: 'prebuildify --napi --strip',
    build: 'pnpm run build:addon && pnpm run prebuild && pnpm run build:ts', // 核心命令：在 CI 机器上执行，将生成的 .node 压缩并放入 prebuilds/ 目录 /* [comment possibly relocated by pnpm] */
    test: 'jest', // --napi 表示这是一个 N-API 模块 (不需要区分 Node 版本) /* [comment possibly relocated by pnpm] */
  },
  dependencies: {
    // 运行时强依赖：它会根据用户的 OS 和 Arch，自动去 prebuilds/ 找对应的 .node
    'node-gyp-build': '^4.8.0',
  },
  devDependencies: {
    '@types/node': '^25.8.0',
    'node-addon-api': '^8.7.0',
    // 开发期依赖：用于生成预编译包
    prebuildify: '^6.0.0',
    typescript: '^6.0.0',
  },
  os: [
    'linux',
    'darwin',
  ],
  cpu: [
    'x64',
    'arm64', // 告诉 npm 包包含预编译的平台特定文件 /* [comment possibly relocated by pnpm] */
  ],
  gypfile: false,
} // 可选：告诉 npm 不需要尝试源码编译 /* [comment possibly relocated by pnpm] */