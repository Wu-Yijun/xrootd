{
  "compilerOptions": {
    /* --- 语言与环境 --- */
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "types": [
      "node"
    ],
    /* --- 类型检查规则 --- */
    "strict": true,
    "skipLibCheck": false,
    "forceConsistentCasingInFileNames": true,
    /* --- 模块化与互操作性 --- */
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    /* --- 输出控制 --- */
    "noEmit": true,
    "rootDir": "./lib"
  },
  "include": [
    "lib/**/*"
  ],
  "exclude": [
    "node_modules",
    "test",
    "**/*.test.ts"
  ]
}